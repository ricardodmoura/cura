APP_NAME=Cura
APP_ENV=local
APP_KEY=
# Em produção: APP_DEBUG=false (caso contrário expõe stack traces e segredos).
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_PT

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Em produção: LOG_LEVEL=warning (debug expõe demasiado em ficheiros de log).
LOG_LEVEL=debug

# Em produção (PostgreSQL recomendado para dados de saúde com encriptação ao nível do disco):
# DB_CONNECTION=pgsql
# DB_HOST=...
# DB_PORT=5432
# DB_DATABASE=cura
# DB_USERNAME=cura
# DB_PASSWORD=...
DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Em produção (dados de saúde): SESSION_ENCRYPT=true.
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false   # Em produção (HTTPS): true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Em produção: MAIL_MAILER=smtp (ou mailgun/ses/postmark) com credenciais reais.
# O driver "log" só serve para dev — emails ficam em storage/logs/laravel.log.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@cura.pt"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
